#!/bin/bash
#SBATCH --job-name=bench-eady
#SBATCH --output=scripts/logs/bench-eady-%j.log
#SBATCH --time=12:00:00
#SBATCH --nodes=1
#SBATCH --partition=gpu-prod
#SBATCH --gres=gpu:h100:1
#SBATCH --mem=64G

# Eady LES SYPD benchmark, paper production resolution (1024×1024×64, WENO(9)),
# adaptive Δt with a 5-day spinup so the wizard equilibrates before measurement.
#
# Wall budget: on tagged Oceananigans 0.107.5 we observe sec/iter ≈ 0.8 at
# production resolution (the WENO enum-bias regression that
# glw/bench-weno-enum-bias was created to measure). With an equilibrated Δt
# around 5–10 s once MLI saturates, the 5-day spinup is ~9–10 h of wall.
# We request 12 h to give margin.
# Override knobs (see benchmarks/README.md): EADY_NX/NY/NZ, EADY_LX/LZ,
# EADY_SPINUP_DAYS, EADY_CFL, EADY_DT0, EADY_MAX_DT.

set -euo pipefail
export PATH="$HOME/.juliaup/bin:$PATH"
export JULIA_CPU_TARGET="generic"

echo "=== Eady LES benchmark (production resolution, adaptive Δt) ==="
hostname; date
nvidia-smi --query-gpu=name,memory.total --format=csv,noheader
echo

cd /shared/home/greg/Projects/OceananigansPaper

# Wrap Julia in a PTY (`script -q -e -c ... /dev/null`) so its stdout/stderr
# is line-buffered even though Slurm redirects --output to a regular file.
# Plain `stdbuf -oL` doesn't help here: Julia's logging goes through libuv,
# not libc stdio, so stdbuf's LD_PRELOAD shim never sees it. Without the PTY,
# Julia block-buffers the entire spinup phase and the slurm log shows nothing
# until the process exits — indistinguishable from a hang.
set +e
script -q -e -c "julia --project benchmarks/eady_les_benchmark.jl" /dev/null
RC=$?
set -e

echo
echo "=== DONE rc=$RC ==="; date
exit $RC
